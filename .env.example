MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/med_super_app?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Used exactly once to seed the first ADMIN account in an empty database.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_FULL_NAME=System Administrator
